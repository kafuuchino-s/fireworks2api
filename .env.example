# fireworks2api environment example
#
# Usage:
# 1. Copy this file to .env.
# 2. Change ADMIN_TOKEN.
# 3. Start with docker compose up -d.
# 4. Add Fireworks API keys and client proxy API keys from the Admin UI.
#
# Backend API behavior follows Fireworks official OpenAI-compatible docs.
# This file is for user-facing deployment configuration. Container internals
# such as HOST and DATA_DIR are handled by Dockerfile/docker-compose.yml.


# ==================== Docker runtime ====================
TZ=Asia/Shanghai
LOG_LEVEL=INFO

# Host port exposed by Docker Compose.
HOST_PORT=8000


# ==================== Authentication ====================
# Admin token protects /admin/* and the Admin UI.
# Change this before exposing the service.
ADMIN_TOKEN=change-me-admin-token

# Optional client token(s) for OpenAI-compatible /v1/* endpoints.
# Prefer managing these from Admin UI -> Config after startup.
# Comma-separated. Example: sk-client-1,sk-client-2
# PROXY_API_KEYS=sk-local-dev


# ==================== Admin static ====================
# Enable packaged Admin-only frontend.
ENABLE_ADMIN_STATIC=true


# ==================== Optional key bootstrap ====================
# Normal users should add Fireworks API keys in Admin UI.
# Use these only for Docker/bootstrap/automation.
# SYNC_ENV_KEYS_ON_STARTUP=false
# FIREWORKS_API_KEYS=fw_key_1,fw_key_2
# FIREWORKS_API_KEYS_JSON=[{"name":"fw1","key":"fw_key_1"},{"name":"fw2","key":"fw_key_2"}]


# ==================== Advanced overrides ====================
# Usually unnecessary. Keep commented unless you know you need them.
# UPSTREAM_BASE_URL=https://api.fireworks.ai/inference/v1
# REQUEST_TIMEOUT_SECONDS=120
# MAX_UPSTREAM_ATTEMPTS=3
# REQUEST_LOG_RETENTION=1000
